{
  "id": "multi-model-review",
  "config": {
    "entries": [
      {
        "key": "api_key",
        "type": "string",
        "secret": true,
        "required": true,
        "global_key": "openrouter.api_key",
        "env": "TABULA_SKILL_MULTI_MODEL_REVIEW_API_KEY",
        "env_aliases": ["OPENROUTER_API_KEY"],
        "store_ids": ["multi-model-review.api_key", "openrouter.api_key"]
      },
      {
        "key": "base_url",
        "type": "string",
        "default": "https://openrouter.ai/api/v1",
        "env": "TABULA_SKILL_MULTI_MODEL_REVIEW_BASE_URL",
        "env_aliases": ["OPENROUTER_BASE_URL"]
      },
      {
        "key": "max_models",
        "type": "int",
        "default": 10,
        "env": "TABULA_SKILL_MULTI_MODEL_REVIEW_MAX_MODELS"
      },
      {
        "key": "concurrency",
        "type": "int",
        "default": 5,
        "env": "TABULA_SKILL_MULTI_MODEL_REVIEW_CONCURRENCY"
      },
      {
        "key": "timeout_sec",
        "type": "int",
        "default": 120,
        "env": "TABULA_SKILL_MULTI_MODEL_REVIEW_TIMEOUT_SEC"
      }
    ]
  }
}
